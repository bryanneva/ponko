{
  "display_information": {
    "name": "Ponko",
    "description": "A self-hosted AI agent that lives in Slack",
    "background_color": "#1a1a2e"
  },
  "features": {
    "bot_user": {
      "display_name": "Ponko",
      "always_online": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "reactions:write",
        "channels:history",
        "channels:read",
        "users:read"
      ],
      "user": [
        "identity.basic"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://YOUR-APP.fly.dev/slack/events",
      "bot_events": [
        "app_mention"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
